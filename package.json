{
  "name": "nebulous-world-anchor",
  "version": "0.1.0",
  "private": true,
  "description": "Anchor workspace (on-chain program + TS test harness) for nebulous.world. The web app lives in app/.",
  "scripts": {
    "dev": "npm --prefix app run dev",
    "build": "npm --prefix app run build",
    "start": "npm --prefix app run start",
    "lint": "npm --prefix app run lint",
    "typecheck": "npm --prefix app run typecheck",
    "db:push": "npm --prefix app run db:push",
    "db:seed": "npm --prefix app run db:seed",
    "db:seed:live": "npm --prefix app run db:seed:live",
    "og:backfill": "npm --prefix app run og:backfill",
    "db:reset": "npm --prefix app run db:reset",
    "db:studio": "npm --prefix app run db:studio",
    "setup:dev": "npm --prefix app run setup:dev",
    "teardown:dev": "npm --prefix app run teardown:dev",
    "dev:all": "npm --prefix app run dev:all",
    "test": "npm --prefix app run test",
    "test:watch": "npm --prefix app run test:watch",
    "test:anchor": "npx anchor test",
    "settle:epoch": "npm --prefix app run settle:epoch",
    "snapshot:daily": "npm --prefix app run snapshot:daily"
  },
  "devDependencies": {
    "@anchor-lang/core": "^1.1.2",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.7.5",
    "chai": "^4.5.0",
    "mocha": "^11.7.6",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.6.3"
  }
}
