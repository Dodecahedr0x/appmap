{
  "name": "nebulous-world",
  "version": "0.1.0",
  "private": true,
  "description": "nebulous.world — crowd-sourced app discovery with Solana-powered voting, tag staking, and traffic-based ad revenue sharing.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "predb:push": "bash scripts/ensure-postgres.sh",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:live": "tsx scripts/seed-live/index.ts",
    "db:reset": "bash scripts/ensure-postgres.sh && prisma db push --force-reset && npm run db:seed",
    "db:studio": "prisma studio",
    "setup:dev": "bash scripts/setup-dev.sh",
    "teardown:dev": "bash scripts/teardown-dev.sh",
    "pretest": "bash scripts/ensure-postgres.sh \"${TEST_DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/nebulous_world_test}\" && DATABASE_URL=\"${TEST_DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/nebulous_world_test}\" npx prisma db push --skip-generate --accept-data-loss",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:anchor": "npx anchor test",
    "settle:epoch": "tsx scripts/settleEpoch.ts",
    "snapshot:daily": "tsx scripts/dailySnapshot.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.95.4",
    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anchor-lang/core": "^1.1.2",
    "@types/bn.js": "^5.2.0",
    "@types/chai": "^4.3.20",
    "@types/d3-force": "^3.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.7.5",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "^10.4.20",
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "mocha": "^11.7.6",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "ts-mocha": "^11.1.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
