# --- Database ---
# Postgres connection string. The app itself never connects to Postgres
# directly (see root AGENTS.md — the indexer owns the database and is the
# only thing that queries it); this var only exists here because
# `indexer/src/config.rs` loads this same file for local `cargo run`
# convenience, so it needs somewhere to read DATABASE_URL from. Locally,
# point at a Postgres instance (e.g.
# `postgresql://postgres:postgres@localhost:5432/nebulous_world_dev`); in
# production Render injects this into the indexer service from the managed
# Postgres instance (see render.yaml).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nebulous_world_dev"

# --- Solana ---
# RPC endpoint. Devnet's public RPC is unreliable for program deploys right
# now, so the nebulous_world program is deployed to a local `solana-test-validator`
# for the time being — run one (`solana-test-validator`) and `anchor deploy
# --provider.cluster localnet` before starting the app. Switch back to
# https://api.devnet.solana.com once devnet deploys are reliable again.
NEXT_PUBLIC_SOLANA_RPC="http://127.0.0.1:8899"
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"

# Optional: a premium mainnet RPC (e.g. Helius, QuickNode) for `setup:dev`'s
# local surfpool Surfnet to fork from instead of the free public
# api.mainnet-beta.solana.com. That free endpoint's rate limit is easily
# tripped by this app's own dev-setup transaction bursts (createAppsOnchain.ts,
# seedStakes.ts each send hundreds of transactions in parallel), which used to
# starve the indexer's crawler and leave a fresh environment with no apps or
# stakes indexed. Leave blank to keep using the free public endpoint (also
# what surfpool itself reads this var name for, see `surfpool start --help`).
SURFPOOL_DATASOURCE_RPC_URL=""

# SPL token mint used for voting & staking (devnet test mint).
# Leave blank to run in "simulation" mode where votes/stakes are recorded
# off-chain without requiring a real on-chain token transfer.
NEXT_PUBLIC_VOTE_TOKEN_MINT=""

# Treasury / program addresses (filled once the Anchor program is deployed).
NEXT_PUBLIC_NEBULOUS_WORLD_PROGRAM_ID="EkQRRgRFd2FUedJnPVs2Xs6N7U2Jef5GrfwJ62UJZUXx"
# Also doubles as the x402 `payTo` address for the priced /api/data/*
# endpoints (see src/lib/x402.ts) — left blank alongside
# NEXT_PUBLIC_VOTE_TOKEN_MINT above, those endpoints serve data for free
# with a `simulated: true` receipt instead of 402ing.
NEXT_PUBLIC_TREASURY_ADDRESS=""

# Number of decimals for the vote token (SPL default is often 6 or 9).
NEXT_PUBLIC_VOTE_TOKEN_DECIMALS="6"

# --- Indexer ---
# Base URL of the indexer's HTTP API (see indexer/src/api.rs). Server-only —
# never exposed to the browser. This app has no Solana RPC connection of its
# own: every on-chain read/write (pool status, vote/stake/claim positions,
# building and submitting transactions) is proxied through the indexer
# instead (see src/lib/indexerClient.ts). `npm run setup:dev` starts the
# indexer locally on this default port.
INDEXER_API_URL="http://127.0.0.1:8090"

# --- App config ---
# Public origin used for metadataBase and absolute OpenGraph/canonical URLs.
# Set to the deployed domain in production (e.g. "https://nebulous.world").
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secret used to sign visitor tracking cookies / anti-tamper. Change in prod.
TRACKING_SECRET="dev-tracking-secret-change-me"

# Footer links (see src/components/Footer.tsx) — all optional, each falls
# back to a sensible default (see src/lib/constants.ts) if unset.
# NEXT_PUBLIC_GITHUB_URL="https://github.com/Dodecahedr0x/appmap"
# NEXT_PUBLIC_TWITTER_URL="https://x.com/Dodecahedr0x"
# NEXT_PUBLIC_DOCS_URL="https://nebulous-world-docs.onrender.com"

# Cloudflare Turnstile keys. A page view only counts as revenue-eligible once
# its token is verified server-side (see src/lib/turnstile.ts). Leave blank
# for local dev — the beacon fires without a token and the server marks such
# views as not revenue-eligible rather than rejecting them.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Simulated ad CPM (revenue in token units per 1000 impressions) used by the
# off-chain revenue engine. Unrelated to real AdSense — this only prices the
# platform's own internal "sponsored app" marketplace (see AdSlot.tsx/
# AdCard.tsx), not the Google-served ads NEXT_PUBLIC_ADSENSE_PUBLISHER_ID
# below controls.
AD_CPM="2.5"

# Google AdSense site tag (Auto ads) — see src/components/ads/AdSenseScript.tsx.
# Loads adsbygoogle.js sitewide so Google can actually serve and place real
# ads; Auto ads decides placement itself, no explicit ad unit markup needed.
# Leave unset to render no real ads at all (e.g. local dev). This is the
# "ca-pub-XXXXXXXXXXXXXXXX" value from AdSense's own site-tag snippet — the
# same underlying account as ADSENSE_ACCOUNT_ID below, just a different
# prefix/format for a different Google API (ad serving vs. the Management
# API used for settlement). Not secret — it's emitted into every page's HTML
# regardless, safe to set directly in render.yaml.
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=""

# --- AdSense settlement (scripts/settleEpoch.ts only — not read by the app
# itself) ---
# Real ad revenue: `npm run settle:epoch` pulls actual AdSense earnings (from
# the real ads NEXT_PUBLIC_ADSENSE_PUBLISHER_ID above renders) and funds
# on-chain reward vaults from them (see src/lib/adsense.ts,
# scripts/settleEpoch.ts). Leave all of these unset to keep running on
# AD_CPM's simulated revenue instead — settle:epoch just isn't runnable
# until they're configured.
#
# ADSENSE_ACCOUNT_ID: the AdSense account id ("pub-XXXXXXXXXXXXXXXX", visible
# in the AdSense dashboard's Account settings) that owns this site's ad units.
#
# ADSENSE_CLIENT_ID / ADSENSE_CLIENT_SECRET: an OAuth 2.0 Client ID (type
# "Desktop app") from a Google Cloud project with the AdSense Management API
# enabled — https://console.cloud.google.com/apis/credentials.
#
# ADSENSE_REFRESH_TOKEN: obtained once via a manual OAuth consent flow using
# the client id/secret above and the `https://www.googleapis.com/auth/adsense.readonly`
# scope (e.g. https://developers.google.com/oauthplayground, gear icon →
# "Use your own OAuth credentials"). AdSense's Management API has no
# service-account auth path, only user consent — but the resulting refresh
# token doesn't expire on its own, so this is a one-time setup, not a
# per-run step. getAdsenseAccessToken() (src/lib/adsense.ts) exchanges it for
# a fresh short-lived access token on every settle:epoch run.
ADSENSE_ACCOUNT_ID=""
ADSENSE_CLIENT_ID=""
ADSENSE_CLIENT_SECRET=""
ADSENSE_REFRESH_TOKEN=""
